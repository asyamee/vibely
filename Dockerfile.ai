# AI Service Dockerfile — Python 3.11 + PyTorch (CPU) + FastAPI
#
# CPU-only сборка PyTorch: при размере embedding-таблиц ~40 МБ и батче 8
# inference и обучение умещаются в CPU за приемлемое время.
# При необходимости GPU — заменить базовый образ на pytorch/pytorch:*-cuda
# и переопределить AI_DEVICE=cuda.

FROM python:3.11-slim

WORKDIR /app

# curl — для healthcheck в docker-compose; gcc — для сборки нативных
# колёс (например, numpy при отсутствии prebuilt wheels)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Сначала только requirements — кэшируем слой установки зависимостей
COPY ai/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Исходники AI-сервиса.
# user_encoder.pt в .gitignore и не попадает в build-контекст —
# веса монтируются volume'ом из docker-compose. Если файла нет на
# момент старта, service.py инициализирует модель со случайными весами.
COPY ai .

# Non-root пользователь для запуска
RUN useradd --create-home --shell /bin/bash aiuser \
    && chown -R aiuser:aiuser /app
USER aiuser

EXPOSE 8000

ENV AI_DEVICE=cpu
ENV AI_MODEL_PATH=user_encoder.pt
ENV PYTHONUNBUFFERED=1

CMD ["uvicorn", "service:app", "--host", "0.0.0.0", "--port", "8000"]
