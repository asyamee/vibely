# =============================================================================
# Production environment для Vibely.
#
# Скопируйте в .env.production и заполните реальными значениями:
#   cp .env.production.example .env.production
#
# ВАЖНО: .env.production должен быть в .gitignore — содержит секреты.
# На сервере файл лежит рядом с docker-compose.deploy.yml и подгружается
# автоматически (docker compose читает .env по умолчанию).
# =============================================================================

# ----- БД ---------------------------------------------------------------------
# Пароль для PostgreSQL. Сгенерируйте: openssl rand -base64 24
DB_PASSWORD=замените_на_надёжный_пароль_не_менее_24_символов

# ----- Yandex Music API -------------------------------------------------------
# Токен и user_id, которые backend использует для запросов к Яндекс Музыке.
# Получение токена описано в документации ym-api или в скриптах backend.
YANDEX_ACCESS_TOKEN=ваш_yandex_music_токен
YANDEX_USER_ID=ваш_yandex_user_id

# ----- JWT --------------------------------------------------------------------
# ДВА разных секрета для access и refresh токенов.
# Сгенерируйте каждый: openssl rand -base64 48
JWT_ACCESS_SECRET=замените_на_длинный_случайный_секрет_access
JWT_REFRESH_SECRET=замените_на_другой_длинный_случайный_секрет_refresh

# Время жизни токенов (формат jsonwebtoken: 15m, 1h, 7d, ...)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- AI-сервис --------------------------------------------------------------
# Общий секрет между backend и AI для admin-эндпоинтов (/admin/retrain и т.п.)
# Сгенерируйте: openssl rand -hex 32
AI_ADMIN_TOKEN=замените_на_случайный_admin_токен

# Устройство для PyTorch. cpu хватит до ~50 тыс. пользователей.
# Для GPU потребуется образ с CUDA (см. Dockerfile.ai).
AI_DEVICE=cpu

# ----- Администраторы ---------------------------------------------------------
# Список user_id (UUID), которым разрешён доступ к /api/admin/*.
# Через запятую без пробелов. Пусто = админский доступ у любого авторизованного
# пользователя (опасно для production!).
ADMIN_USER_IDS=

# ----- Сеть -------------------------------------------------------------------
# Публичный домен. Обязательно включите схему (https://).
# Должен совпадать с CN в SSL-сертификате.
CORS_ORIGIN=https://your-domain.com

# Домен для cookie с refresh-токеном.
# Без точки впереди = только основной домен; с точкой = поддомены тоже.
# Пример: ".your-domain.com" или "your-domain.com"
COOKIE_DOMAIN=your-domain.com

# URL backend, который инлайнится в JS-бандл frontend на этапе сборки.
# Если фронт и бэк за одним nginx — оставьте /api (относительный путь).
NEXT_PUBLIC_BACKEND_URL=/api

# =============================================================================
# Только для GitHub Actions deploy workflow (НЕ копируется на сервер,
# хранится в GitHub Secrets):
#   SSH_HOST       — IP или hostname сервера
#   SSH_USER       — пользователь для SSH (обычно deploy или ubuntu)
#   SSH_KEY        — приватный ключ (содержимое id_ed25519)
#   GHCR_PAT       — Personal Access Token для pull из ghcr.io (если репо приватный)
# =============================================================================
