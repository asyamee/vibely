# Docker Environment Variables
# Скопируйте в .env.docker и заполните реальные значения

# ========== Database ==========
DB_PASSWORD=vibely_password_change_me

# ========== Yandex Music API ==========
# Получите на https://music.yandex.ru/
YANDEX_ACCESS_TOKEN=your_yandex_music_token_here
YANDEX_USER_ID=your_yandex_user_id_here

# ========== JWT Secrets ==========
# Генерируйте криптографически безопасные значения:
# openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ========== AI Service ==========
# cpu или cuda (если есть GPU)
AI_DEVICE=cpu

# ========== Optional: Domain и SSL ==========
# Если используете Nginx/Traefik с доменом:
# DOMAIN=your-domain.com
# LETSENCRYPT_EMAIL=your-email@example.com
